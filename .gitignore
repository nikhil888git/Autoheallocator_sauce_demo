# ==============================
# 🔹 BASE LOG DIRECTORY
# ==============================

# Ignore everything inside logs
logs/**

# Keep folder structure
!logs/.gitkeep


# ==============================
# 🔹 RUNTIME EXECUTION LOGS (IGNORE)
# ==============================

logs/runtime/
logs/api/
logs/playwright/

*.log
*.out


# ==============================
# 🔹 CI/CD EXECUTION LOGS (STRUCTURED)
# ==============================

logs/ci/

# Keep only critical CI failure logs
!logs/ci/error.log
!logs/ci/failure.log
!logs/ci/critical.log


# ==============================
# 🔹 ERROR LOGS (PARTIAL TRACKING)
# ==============================

logs/errors/

# Allow only meaningful error logs
!logs/errors/*.log
!logs/errors/failure-summary.json


# ==============================
# 🔹 AUDIT LOGS (ENTERPRISE TRACEABILITY)
# ==============================

logs/audit/

# Keep structured audit logs
!logs/audit/*.json


# ==============================
# 🔹 API LOGS (ISOLATED)
# ==============================

http-logs/
api-logs/
wiremock-logs/


# ==============================
# 🔹 PLAYWRIGHT EXECUTION LOGS
# ==============================

playwright-report/
test-results/
blob-report/


# ==============================
# 🔹 AI AUTO-HEAL LOGGING (USP)
# ==============================

tmp-autoheal/
ai-cache/

logs/ai-heal/

# Keep only decision summary
!logs/ai-heal/healing-summary.json


# ==============================
# 🔹 REPORTING FRAMEWORKS
# ==============================

allure-results/
allure-report/
extent-reports/
test-output/
surefire-reports/
failsafe-reports/


# ==============================
# 🔹 TEMP FILES
# ==============================

*.tmp
*.swp
*.bak
*.old
*.orig
*~